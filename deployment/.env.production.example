# Lume Framework - Production Environment Configuration
# Copy this file to .env and fill in your production values
# IMPORTANT: Never commit .env to version control

# Core Application
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com
LOG_LEVEL=info

# Database Configuration
DB_HOST=mysql.internal
DB_PORT=3306
DB_NAME=lume
DB_USER=lume_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSL=true
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_TIMEOUT=30000

# JWT & Authentication
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRATION=1h
REFRESH_TOKEN_SECRET=CHANGE_ME_GENERATE_RANDOM_STRING_MIN_32_CHARS
REFRESH_TOKEN_EXPIRATION=7d

# CORS & Security
CORS_ORIGIN=https://your-domain.com
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_STRING

# Admin API Security
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY
ADMIN_API_SECRET=CHANGE_ME_ADMIN_API_SECRET

# Email/SMTP Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_SENDGRID_API_KEY
SMTP_FROM=noreply@your-domain.com
SMTP_FROM_NAME=Lume Framework

# AI/LLM Configuration
AI_PROVIDER=anthropic
AI_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY
AI_MODEL=claude-haiku-4-5
AI_MAX_TOKENS=500

# File Storage (S3 Configuration)
STORAGE_TYPE=s3
AWS_S3_BUCKET=lume-uploads-prod
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
AWS_S3_ACL=private
MAX_FILE_SIZE=52428800  # 50MB

# Redis (Optional but Recommended for Production)
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_SSL=true
CACHE_TTL=3600

# Module Configuration
LOAD_EXAMPLE_MODULES=false
AUTO_MIGRATE_MODULES=true
VERBOSE_MODULE_LOGGING=false

# Monitoring & Error Tracking
SENTRY_DSN=CHANGE_ME_SENTRY_DSN
SENTRY_ENVIRONMENT=production
SENTRY_TRACE_SAMPLE_RATE=0.1
DATADOG_API_KEY=CHANGE_ME_DATADOG_API_KEY
DATADOG_ENV=production

# Logging
LOG_SERVICE=datadog
LOG_FORMAT=json
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# Timezone
TZ=UTC

# Feature Flags
ENABLE_ADMIN_DASHBOARD=true
ENABLE_PLUGINS=true
ENABLE_WORKFLOWS=true
ENABLE_AI_FEATURES=true

# Security Headers
HELMET_CSP_ENABLED=true
HELMET_HSTS_MAX_AGE=31536000

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is currently under maintenance. Please try again later.

# Rate Limiting per Endpoint (optional)
RATE_LIMIT_AUTH=5/15min
RATE_LIMIT_API=100/1min
RATE_LIMIT_UPLOAD=10/1hour

# Database Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# API Response Limits
MAX_REQUEST_BODY_SIZE=52428800  # 50MB
MAX_JSON_PAYLOAD_SIZE=52428800
PAGINATION_MAX_LIMIT=1000
PAGINATION_DEFAULT_LIMIT=25

# Performance Optimization
DB_QUERY_TIMEOUT=30000
GRAPHQL_DEPTH_LIMIT=10
GRAPHQL_COMPLEXITY_LIMIT=1000

# Webhook Configuration (if webhooks enabled)
WEBHOOK_TIMEOUT=30000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5000

# Third-party Integrations (optional)
STRIPE_PUBLIC_KEY=CHANGE_ME_IF_STRIPE_ENABLED
STRIPE_SECRET_KEY=CHANGE_ME_IF_STRIPE_ENABLED
GITHUB_TOKEN=CHANGE_ME_IF_GITHUB_INTEGRATION
SLACK_WEBHOOK_URL=CHANGE_ME_IF_SLACK_NOTIFICATIONS

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_PATH=/api/docs
OPENAPI_TITLE=Lume Framework API
OPENAPI_VERSION=2.0.0
OPENAPI_DESCRIPTION=Metadata-driven enterprise platform with modules, workflows, and policies

# Metrics & Telemetry
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
TELEMETRY_SAMPLE_RATE=0.1

# Advanced Settings (Tune only if experienced)
CONNECTION_POOL_MAX_IDLE=30000
CONNECTION_POOL_MIN_IDLE=2
WORKER_THREADS=4
MAX_BODY_SIZE=100mb
COMPRESSION_LEVEL=6

{
  "extends": "./packages/@lume/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@lume/*": ["packages/@lume/*/src"],
      "@backend/*": ["backend/src/*"],
      "@modules/*": ["backend/src/modules/*"]
    }
  },
  "include": [
    "backend/**/*.ts",
    "apps/**/*.ts",
    "apps/**/*.vue",
    "packages/**/*.ts"
  ],
  "exclude": ["node_modules"]
}

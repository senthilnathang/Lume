{
  "extends": "./base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "src/**/*",
    "src/**/*.vue",
    "tests/**/*"
  ],
  "exclude": ["node_modules", "dist", ".nuxt"]
}

# FastVue Package Configuration
# Shared dependencies for the modular workspace

# Main package.json
{
  "name": "gawdesy-workspace",
  "version": "1.0.0",
  "description": "GAWDESY Project Workspace - Full-Stack Monorepo with Shared Dependencies",
  "type": "module",
  "private": true,
  "keywords": [
    "gawdesy",
    "ngo", 
    "vue",
    "vue3", 
    "vben",
    "fastvue",
    "fastapi",
    "nuxtjs",
    "typescript",
    "postgresql",
    "pytest",
    "playwright"
  ],
  "scripts": {
    "dev": "npm run dev",
    "dev:admin": "npm run dev:admin", 
    "dev:website": "npm run dev:website",
    "dev:api": "npm run dev:api",
    "build": "npm run build",
    "test": "npm run test",
    "test:e2e": "playwright test",
    "lint": "npm run lint", 
    "format": "npm run format",
    "type-check": "npm run type-check",
    "build:clean": "rimraf dist && rimraf .nitro-cache",
    "deploy": "npm run build && npm run start"
  },
  "devDependencies": {
    "@nvtw": "^3.2.4"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "@vitejs/plugin-vue": "^5.4.0",
    "@vitest": "^2.1.0",
    "@playwright/test": "^1.49.0",
    "@typescript": "^5.6.0",
    "eslint": "^8.57.0",
    "shared": "workspace:*",
    "config": {
      "shared": "workspace:*"
    }
  },
  "engines": {
    "node": ">=18.19.0"
  }
  }
}
{
  "name": "@lume/web",
  "version": "1.0.0",
  "description": "Lume Framework - Vue.js Application with Modular Architecture",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",

{
  "name": "gawdesy-frontend",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "gawdesy",
    "vue",
    "vue3",
    "vben",
    "ngo",
    "nonprofit"
  ],
  "description": "Gawdesy NGO Website - Vue.js Frontend",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo build",
    "build:web": "pnpm run build --filter=@gawdesy/web",
    "check": "pnpm run check:type",
    "check:type": "turbo run typecheck",
    "clean": "node ./scripts/clean.mjs",
    "dev": "turbo-run dev",
    "dev:web": "pnpm -F @gawdesy/web run dev",
    "format": "vsh lint --format",
    "lint": "vsh lint",
    "postinstall": "pnpm -r run stub --if-present",
    "preinstall": "npx only-allow pnpm",
    "preview": "turbo-run preview",
    "reinstall": "pnpm clean --del-lock && pnpm install",
    "test:unit": "vitest run --dom",
    "test:unit:watch": "vitest --dom",
    "test:unit:coverage": "vitest run --dom --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.49.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@vben/commitlint-config": "workspace:*",
    "@vben/eslint-config": "workspace:*",
    "@vben/prettier-config": "workspace:*",
    "@vben/stylelint-config": "workspace:*",
    "@vben/tailwind-config": "workspace:*",
    "@vben/tsconfig": "workspace:*",
    "@vben/turbo-run": "workspace:*",
    "@vben/vite-config": "workspace:*",
    "@vben/vsh": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^30.2.0",
    "cross-env": "^7.0.3",
    "happy-dom": "^16.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "msw": "^2.12.8",
    "playwright": "^1.49.0",
    "rimraf": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "unbuild": "^3.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "vue-tsc": "^2.1.0"
  },
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "*"
      }
    },
    "overrides": {
      "@ast-grep/napi": "^0.28.0",
      "@ctrl/tinycolor": "^4.1.0",
      "clsx": "^2.1.0",
      "esbuild": "^0.25.0",
      "jiti": "^2.4.0",
      "pinia": "^2.2.0",
      "vue": "^3.5.0"
    },
    "neverBuiltDependencies": [
      "canvas",
      "node-gyp"
    ]
  },
  "dependencies": {
    "vue-sfc-transformer": "^0.1.17",
    "vue3-sfc-loader": "^0.9.5"
  }
}

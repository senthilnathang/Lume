{
  "name": "gawdesy-admin",
  "version": "2.0.0",
  "description": "Enhanced GAWDESY Admin Dashboard - FastVue Framework Integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest && vitest watch",
    "lint": "eslint . && vue-tsc --fix",
    "type-check": "vue-tsc --no-emit",
    "build:clean": "rimraf dist && rimraf .nitro-cache",
    "analyze": "vue-tsc --no-emit",
    "deploy": "vite build && npm run start"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "pinia": "^2.2.0",
    "vueuse": "^4.5.0",
    "axios": "^1.7.0",
    "ant-design-vue": "^4.2.0",
    "@vitejs/plugin-vue": "^5.4.0",
    "@vue/compiler-sfc": "^3.5.0",
    "@vueuse/core": "^10.9.0",
    "@vueuse/integrations": "^10.2.0",
    "@ant-design/icons-vue": "^7.0.0",
    "@element-plus/icons-vue": "^2.3.1",
    "@iconify/json": "^0.1.0",
    "@types/node": "^22.7.0",
    "tailwindcss": "^3.4.0",
    "unplugin-auto-import": "^0.18.1",
    "pinia/testing": "^1.0.3",
    "nvtw": "^3.2.4",
    "@fastvue/adminlte": "^0.0.5",
    "@fastvue/boot": "^0.0.5",
    "@fastvue/utils": "^0.0.4",
    "@fastvue/common-ui": "^0.0.8",
    "@fastvue/forms": "^0.0.4",
    "@fastvue/charts": "^0.0.5",
    "@fastvue/eslint-config": "^8.56.0",
    "typescript": "^5.6.0",
    "element-plus/icons-vue": "^2.3.1",
    "unplugin-vue": "^5.5.0",
    "lodash-es": "^4.17.21",
    "dayjs": "^1.11.10",
    "npm": "^10.8.0"
  }

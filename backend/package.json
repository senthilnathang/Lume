{
  "name": "lume-backend",
  "version": "1.0.0",
  "description": "Lume Framework - Modular Backend API with Dynamic Database Support",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "dev:mysql": "DB_TYPE=mysql nodemon src/index.js",
    "dev:postgres": "DB_TYPE=postgres nodemon src/index.js",
    "build": "echo 'No build step required'",
    "test": "jest",
    "lint": "eslint src/",
    "db:seed": "node src/scripts/seedData.js",
    "db:admin": "node src/scripts/createAdmin.js",
    "db:refresh": "node src/scripts/refreshDb.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    
    "sequelize": "^6.37.0",
    "mysql2": "^3.6.5",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "express-session": "^1.17.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    
    "nodemailer": "^6.9.7",
    "multer": "^1.4.5-lts.1",
    
    "dayjs": "^1.11.10",
    "lodash-es": "^4.17.21",
    
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "eslint": "^8.56.0",
    "yargs": "^17.7.2",
    "@types/yargs": "^17.0.32",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
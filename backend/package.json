{
  "name": "lume-backend",
  "version": "2.0.0",
  "description": "Lume Framework v2.0 - Modular Backend API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "dev:mysql": "DB_TYPE=mysql nodemon src/index.js",
    "dev:postgres": "DB_TYPE=postgres nodemon src/index.js",
    "build": "echo 'No build step required'",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "db:init": "node src/scripts/initDb.js --seed",
    "db:init:force": "node src/scripts/initDb.js --seed --force",
    "db:seed": "node src/scripts/seedData.js",
    "db:admin": "node src/scripts/createAdmin.js",
    "db:refresh": "node src/scripts/refreshDb.js",
    "clean": "rm -rf dist coverage .jest"
  },
  "dependencies": {
    "@bull-board/express": "^7.0.0",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.75.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.20",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.0",
    "express-session": "^1.17.3",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "lodash-es": "^4.17.21",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.7",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "prisma": "^5.18.0",
    "qrcode": "^1.5.4",
    "redis": "^4.6.12",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "winston": "^3.14.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/yargs": "^17.0.32",
    "drizzle-kit": "^0.31.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "yargs": "^17.7.2"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}

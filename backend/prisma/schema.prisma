  password_hash    String?   @db.VarChar(255)
  locked_by        Int?
  locked_at        DateTime? @db.Timestamp(0)
}

model website_popups {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(255)
  content       String?   @db.LongText
  content_html  String?   @db.LongText
  trigger_type  String?   @default("page-load") @db.VarChar(20)
  trigger_value String?   @db.VarChar(100)
  position      String?   @default("center") @db.VarChar(20)
  width         String?   @default("md") @db.VarChar(20)
  overlay_close Boolean?  @default(true)
  show_once     Boolean?  @default(true)
  conditions    String?   @db.LongText
  is_active     Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
}

model website_redirects {
  id          Int       @id @default(autoincrement())
  source_path String    @db.VarChar(500)
  target_path String    @db.VarChar(500)
  status_code Int?      @default(301)
  hits        Int?      @default(0)
  is_active   Boolean?  @default(true)
  created_at  DateTime  @default(now()) @db.Timestamp(0)
  updated_at  DateTime  @default(now()) @db.Timestamp(0)
  deleted_at  DateTime? @db.Timestamp(0)
}

model website_settings {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)
  key        String   @unique(map: "idx_key") @db.VarChar(100)
  value      String?  @db.Text
  type       String?  @default("string") @db.VarChar(20)
}

model website_tags {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  slug       String    @unique(map: "slug") @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)
}

model website_theme_templates {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  type         String?   @default("header") @db.VarChar(20)
  content      String?   @db.LongText
  content_html String?   @db.LongText
  conditions   String?   @db.LongText
  priority     Int?      @default(10)
  is_active    Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  updated_at   DateTime? @default(now()) @db.Timestamp(0)
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model activities {
  id                Int                @id @default(autoincrement())
  title             String             @db.VarChar(255)
  slug              String             @unique(map: "slug") @db.VarChar(255)
  description       String?            @db.Text
  short_description String?            @db.VarChar(500)
  category          String?            @db.VarChar(100)
  status            activities_status? @default(draft)
  start_date        DateTime?          @db.DateTime(0)
  end_date          DateTime?          @db.DateTime(0)
  location          String?            @db.VarChar(255)
  cover_image       String?            @db.VarChar(500)
  gallery           String?            @db.LongText
  capacity          Int?
  registered_count  Int?               @default(0)
  is_featured       Boolean?           @default(false)
  metadata          String?            @db.LongText
  created_by        Int?
  published_at      DateTime?          @db.DateTime(0)
  created_at        DateTime           @default(now()) @db.DateTime(0)
  updated_at        DateTime           @default(now()) @updatedAt @db.DateTime(0)
  users             User?              @relation(fields: [created_by], references: [id], map: "activities_ibfk_1")

  @@index([category], map: "activities_category")
  @@index([is_featured], map: "activities_is_featured")
  @@index([slug], map: "activities_slug")
  @@index([start_date], map: "activities_start_date")
  @@index([status], map: "activities_status")
  @@index([created_by], map: "created_by")
}

model api_keys {
  id           Int              @id @default(autoincrement())
  name         String           @db.VarChar(100)
  key          String           @unique(map: "key") @db.VarChar(255)
  prefix       String           @db.VarChar(20)
  user_id      Int?
  expires_at   DateTime?        @db.DateTime(0)
  last_used_at DateTime?        @db.DateTime(0)
  status       api_keys_status? @default(active)
  scopes       String?          @db.LongText
  created_at   DateTime         @default(now()) @db.DateTime(0)
  updated_at   DateTime         @default(now()) @updatedAt @db.DateTime(0)
}

model attachments {
  id              Int      @id @default(autoincrement())
  file_name       String   @db.VarChar(255)
  file_path       String   @db.VarChar(500)
  file_size       Int?
  mime_type       String?  @db.VarChar(100)
  attachable_type String   @db.VarChar(100)
  attachable_id   Int
  uploaded_by     Int?
  created_at      DateTime @default(now()) @db.DateTime(0)
  updated_at      DateTime @default(now()) @updatedAt @db.DateTime(0)
}

model AuditLog {
  id        Int               @id @default(autoincrement())
  action    audit_logs_action
  model     String?           @db.VarChar(100)
  recordId  String?           @map("record_id") @db.VarChar(100)
  oldValues String?           @map("old_values") @db.LongText
  newValues String?           @map("new_values") @db.LongText
  userId    Int?              @map("user_id")
  ipAddress String?           @map("ip_address") @db.VarChar(45)
  userAgent String?           @map("user_agent") @db.Text
  createdAt DateTime?         @map("created_at") @db.DateTime(0)
  updatedAt DateTime?         @map("updated_at") @db.DateTime(0)

  @@index([action], map: "audit_logs_action")
  @@index([userId], map: "audit_logs_user_id")
  @@map("audit_logs")
}

model automation_approval_chains {
  id          Int                                @id @default(autoincrement())
  name        String                             @db.VarChar(100)
  model       String                             @db.VarChar(100)
  description String?                            @db.Text
  steps       String?                            @db.LongText
  condition   String?                            @db.LongText
  status      automation_approval_chains_status? @default(active)
  created_at  DateTime                           @default(now()) @db.DateTime(0)
  updated_at  DateTime                           @default(now()) @updatedAt @db.DateTime(0)
}

model automation_assignment_rules {
  id          Int                                    @id @default(autoincrement())
  name        String                                 @db.VarChar(100)
  model       String                                 @db.VarChar(100)
  description String?                                @db.Text
  assign_to   automation_assignment_rules_assign_to? @default(user)
  assignee_id Int?
  condition   String?                                @db.LongText
  priority    Int?                                   @default(10)
  status      automation_assignment_rules_status?    @default(active)
  created_at  DateTime                               @default(now()) @db.DateTime(0)
  updated_at  DateTime                               @default(now()) @updatedAt @db.DateTime(0)
}

model automation_business_rules {
  id          Int                               @id @default(autoincrement())
  name        String                            @db.VarChar(100)
  model       String                            @db.VarChar(100)
  field       String                            @db.VarChar(100)
  description String?                           @db.Text
  condition   String?                           @db.LongText
  action      String?                           @db.LongText
  priority    Int?                              @default(10)
  status      automation_business_rules_status? @default(active)
  created_at  DateTime                          @default(now()) @db.DateTime(0)
  updated_at  DateTime                          @default(now()) @updatedAt @db.DateTime(0)
}

model automation_flows {
  id          Int                       @id @default(autoincrement())
  name        String                    @db.VarChar(100)
  model       String                    @db.VarChar(100)
  description String?                   @db.Text
  nodes       String?                   @db.LongText
  edges       String?                   @db.LongText
  trigger     automation_flows_trigger? @default(manual)
  status      automation_flows_status?  @default(draft)
  created_at  DateTime                  @default(now()) @db.DateTime(0)
  updated_at  DateTime                  @default(now()) @updatedAt @db.DateTime(0)
}

model automation_rollup_fields {
  id               Int                                 @id @default(autoincrement())
  name             String                              @db.VarChar(100)
  parent_model     String                              @db.VarChar(100)
  child_model      String                              @db.VarChar(100)
  rollup_field     String                              @db.VarChar(100)
  target_field     String                              @db.VarChar(100)
  operation        automation_rollup_fields_operation? @default(sum)
  filter_condition String?                             @db.LongText
  description      String?                             @db.Text
  status           automation_rollup_fields_status?    @default(active)
  created_at       DateTime                            @default(now()) @db.DateTime(0)
  updated_at       DateTime                            @default(now()) @updatedAt @db.DateTime(0)
}

model automation_scheduled_actions {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(100)
  model           String?   @db.VarChar(100)
  description     String?   @db.Text
  action_type     String?   @default("code") @db.VarChar(30)
  config          String?   @db.LongText
  cron_expression String?   @db.VarChar(100)
  interval        Int?
  interval_unit   String?   @default("hours") @db.VarChar(20)
  last_run_at     DateTime? @db.DateTime(0)
  next_run_at     DateTime? @db.DateTime(0)
  status          String?   @default("active") @db.VarChar(20)
  created_at      DateTime  @default(now()) @db.DateTime(0)
  updated_at      DateTime  @default(now()) @updatedAt @db.DateTime(0)
}

model automation_validation_rules {
  id            Int                                    @id @default(autoincrement())
  name          String                                 @db.VarChar(100)
  model         String                                 @db.VarChar(100)
  field         String?                                @db.VarChar(100)
  description   String?                                @db.Text
  rule_type     automation_validation_rules_rule_type? @default(required)
  config        String?                                @db.LongText
  error_message String?                                @db.VarChar(255)
  priority      Int?                                   @default(10)
  status        automation_validation_rules_status?    @default(active)
  created_at    DateTime                               @default(now()) @db.DateTime(0)
  updated_at    DateTime                               @default(now()) @updatedAt @db.DateTime(0)
}

model automation_workflows {
  id            Int                          @id @default(autoincrement())
  name          String                       @db.VarChar(100)
  model         String                       @db.VarChar(100)
  description   String?                      @db.Text
  states        String?                      @db.LongText
  transitions   String?                      @db.LongText
  initial_state String?                      @db.VarChar(50)
  status        automation_workflows_status? @default(draft)
  created_at    DateTime                     @default(now()) @db.DateTime(0)
  updated_at    DateTime                     @default(now()) @updatedAt @db.DateTime(0)
}

model backups {
  id         Int             @id @default(autoincrement())
  name       String          @db.VarChar(255)
  type       backups_type?   @default(full)
  file_path  String?         @db.VarChar(500)
  file_size  BigInt?
  tables     String?         @db.LongText
  status     backups_status? @default(pending)
  created_by Int?
  created_at DateTime        @default(now()) @db.DateTime(0)
  updated_at DateTime        @default(now()) @updatedAt @db.DateTime(0)
}

model campaigns {
  id            Int               @id @default(autoincrement())
  name          String            @db.VarChar(255)
  slug          String            @unique(map: "slug") @db.VarChar(255)
  description   String?           @db.Text
  goal_amount   Decimal?          @db.Decimal(12, 2)
  raised_amount Decimal?          @default(0.00) @db.Decimal(12, 2)
  start_date    DateTime?         @db.DateTime(0)
  end_date      DateTime?         @db.DateTime(0)
  status        campaigns_status? @default(draft)
  cover_image   String?           @db.VarChar(500)
  is_featured   Boolean?          @default(false)
  metadata      String?           @db.LongText
  created_at    DateTime          @default(now()) @db.DateTime(0)
  updated_at    DateTime          @default(now()) @updatedAt @db.DateTime(0)
  donations     donations[]

  @@index([slug], map: "campaigns_slug")
  @@index([status], map: "campaigns_status")
}

model comments {
  id               Int      @id @default(autoincrement())
  body             String   @db.Text
  commentable_type String   @db.VarChar(100)
  commentable_id   Int
  parent_id        Int?
  user_id          Int
  created_at       DateTime @default(now()) @db.DateTime(0)
  updated_at       DateTime @default(now()) @updatedAt @db.DateTime(0)
}

model custom_fields {
  id            Int                       @id @default(autoincrement())
  name          String                    @db.VarChar(100)
  label         String                    @db.VarChar(100)
  model         String                    @db.VarChar(100)
  field_type    custom_fields_field_type? @default(text)
  options       String?                   @db.LongText
  default_value String?                   @db.VarChar(255)
  required      Boolean?                  @default(false)
  unique        Boolean?                  @default(false)
  help_text     String?                   @db.VarChar(255)
  placeholder   String?                   @db.VarChar(255)
  sequence      Int?                      @default(10)
  group         String?                   @db.VarChar(100)
  status        custom_fields_status?     @default(active)
  created_at    DateTime                  @default(now()) @db.DateTime(0)
  updated_at    DateTime                  @default(now()) @updatedAt @db.DateTime(0)
}

model custom_views {
  id         Int                     @id @default(autoincrement())
  name       String                  @db.VarChar(100)
  model      String                  @db.VarChar(100)
  view_type  custom_views_view_type? @default(list)
  config     String?                 @db.LongText
  filters    String?                 @db.LongText
  sort_by    String?                 @db.LongText
  columns    String?                 @db.LongText
  is_default Boolean?                @default(false)
  is_shared  Boolean?                @default(false)
  created_by Int?
  status     custom_views_status?    @default(active)
  created_at DateTime                @default(now()) @db.DateTime(0)
  updated_at DateTime                @default(now()) @updatedAt @db.DateTime(0)
}

model dashboard_widgets {
  id               Int                            @id @default(autoincrement())
  name             String                         @db.VarChar(100)
  widget_type      dashboard_widgets_widget_type? @default(counter)
  model            String?                        @db.VarChar(100)
  config           String?                        @db.LongText
  position         String?                        @db.LongText
  refresh_interval Int?                           @default(0)
  roles            String?                        @db.LongText
  status           dashboard_widgets_status?      @default(active)
  created_at       DateTime                       @default(now()) @db.DateTime(0)
  updated_at       DateTime                       @default(now()) @updatedAt @db.DateTime(0)
}

model data_exports {
  id           Int                  @id @default(autoincrement())
  name         String               @db.VarChar(255)
  model        String               @db.VarChar(100)
  filters      String?              @db.LongText
  fields       String?              @db.LongText
  format       data_exports_format? @default(csv)
  file_path    String?              @db.VarChar(500)
  file_size    Int?
  record_count Int?                 @default(0)
  status       data_exports_status? @default(pending)
  exported_by  Int?
  created_at   DateTime             @default(now()) @db.DateTime(0)
  updated_at   DateTime             @default(now()) @updatedAt @db.DateTime(0)
}

model data_imports {
  id             Int                  @id @default(autoincrement())
  name           String               @db.VarChar(255)
  model          String               @db.VarChar(100)
  file_name      String?              @db.VarChar(255)
  file_path      String?              @db.VarChar(500)
  mapping        String?              @db.LongText
  total_rows     Int?                 @default(0)
  processed_rows Int?                 @default(0)
  success_rows   Int?                 @default(0)
  failed_rows    Int?                 @default(0)
  errors         String?              @db.LongText
  status         data_imports_status? @default(pending)
  imported_by    Int?
  created_at     DateTime             @default(now()) @db.DateTime(0)
  updated_at     DateTime             @default(now()) @updatedAt @db.DateTime(0)
}

model documents {
  id            Int             @id @default(autoincrement())
  title         String          @db.VarChar(255)
  filename      String          @db.VarChar(255)
  original_name String?         @db.VarChar(255)
  mime_type     String?         @db.VarChar(100)
  size          Int?
  type          documents_type? @default(document)
  category      String?         @db.VarChar(100)
  path          String          @db.VarChar(500)
  url           String?         @db.VarChar(500)
  description   String?         @db.Text
  tags          String?         @db.LongText
  uploaded_by   Int?
  is_public     Boolean?        @default(false)
  downloads     Int?            @default(0)
  metadata      String?         @db.LongText
  created_at    DateTime        @default(now()) @db.DateTime(0)
  updated_at    DateTime        @default(now()) @updatedAt @db.DateTime(0)
  users         User?           @relation(fields: [uploaded_by], references: [id], map: "documents_ibfk_1")

  @@index([category], map: "documents_category")
  @@index([is_public], map: "documents_is_public")
  @@index([type], map: "documents_type")
  @@index([uploaded_by], map: "documents_uploaded_by")
}

model donations {
  id              Int                       @id @default(autoincrement())
  donor_id        Int?
  amount          Decimal                   @db.Decimal(10, 2)
  currency        String?                   @default("USD") @db.VarChar(3)
  status          donations_status?         @default(pending)
  payment_method  donations_payment_method?
  transaction_id  String?                   @db.VarChar(255)
  payment_gateway String?                   @db.VarChar(50)
  campaign_id     Int?
  activity_id     Int?
  designation     String?                   @db.VarChar(255)
  is_recurring    Boolean?                  @default(false)
  frequency       donations_frequency?      @default(one_time)
  receipt_sent    Boolean?                  @default(false)
  receipt_sent_at DateTime?                 @db.DateTime(0)
  notes           String?                   @db.Text
  anonymous       Boolean?                  @default(false)
  metadata        String?                   @db.LongText
  created_at      DateTime                  @default(now()) @db.DateTime(0)
  updated_at      DateTime                  @default(now()) @updatedAt @db.DateTime(0)
  donors          donors?                   @relation(fields: [donor_id], references: [id], map: "donations_ibfk_1")
  campaigns       campaigns?                @relation(fields: [campaign_id], references: [id], map: "donations_ibfk_2")

  @@index([campaign_id], map: "campaign_id")
  @@index([created_at], map: "donations_created_at")
  @@index([donor_id], map: "donations_donor_id")
  @@index([status], map: "donations_status")
  @@index([transaction_id], map: "donations_transaction_id")
}

model donors {
  id            Int         @id @default(autoincrement())
  first_name    String      @db.VarChar(100)
  last_name     String      @db.VarChar(100)
  email         String      @db.VarChar(255)
  phone         String?     @db.VarChar(20)
  address       String?     @db.Text
  city          String?     @db.VarChar(100)
  state         String?     @db.VarChar(100)
  country       String?     @db.VarChar(100)
  postal_code   String?     @db.VarChar(20)
  is_anonymous  Boolean?    @default(false)
  is_subscribed Boolean?    @default(true)
  notes         String?     @db.Text
  metadata      String?     @db.LongText
  created_at    DateTime    @default(now()) @db.DateTime(0)
  updated_at    DateTime    @default(now()) @updatedAt @db.DateTime(0)
  donations     donations[]

  @@index([email], map: "donors_email")
  @@index([first_name, last_name], map: "donors_first_name_last_name")
}

model feature_flags {
  id           Int       @id @default(autoincrement())
  name         String    @unique(map: "name") @db.VarChar(100)
  key          String    @unique(map: "key") @db.VarChar(100)
  description  String?   @db.Text
  enabled      Boolean?  @default(false)
  enabled_for  String?   @db.LongText
  disabled_for String?   @db.LongText
  config       String?   @db.LongText
  expires_at   DateTime? @db.DateTime(0)
  sequence     Int?      @default(10)
  created_at   DateTime  @default(now()) @db.DateTime(0)
  updated_at   DateTime  @default(now()) @updatedAt @db.DateTime(0)
}

model form_layouts {
  id         Int                  @id @default(autoincrement())
  name       String               @db.VarChar(100)
  model      String               @db.VarChar(100)
  layout     String?              @db.LongText
  is_default Boolean?             @default(false)
  status     form_layouts_status? @default(active)
  created_at DateTime             @default(now()) @db.DateTime(0)
  updated_at DateTime             @default(now()) @updatedAt @db.DateTime(0)
}

model Group {
  id          Int       @id @default(autoincrement())
  name        String    @unique(map: "name") @db.VarChar(100)
  description String?   @db.Text
  isActive    Boolean?  @default(true) @map("is_active")
  createdAt   DateTime? @map("created_at") @db.DateTime(0)
  updatedAt   DateTime? @map("updated_at") @db.DateTime(0)

  @@map("groups")
}

model InstalledModule {
  id            Int                     @id @default(autoincrement())
  name          String                  @unique(map: "name") @db.VarChar(100)
  displayName   String                  @map("display_name") @db.VarChar(200)
  version       String                  @default("1.0.0") @db.VarChar(50)
  state         installed_modules_state @default(uninstalled)
  depends       String                  @db.LongText
  manifestCache String?                 @map("manifest_cache") @db.LongText
  modulePath    String?                 @map("module_path") @db.VarChar(500)
  installedAt   DateTime?               @map("installed_at") @db.DateTime(0)
  updatedAt     DateTime?               @map("updated_at") @db.DateTime(0)
  sequence      Int?
  createdAt     DateTime?               @map("created_at") @db.DateTime(0)

  @@index([name], map: "installed_modules_name")
  @@index([sequence], map: "installed_modules_sequence")
  @@index([state], map: "installed_modules_state")
  @@map("installed_modules")
}

model ip_access {
  id          Int               @id @default(autoincrement())
  ip_address  String            @unique(map: "ip_address") @db.VarChar(45)
  description String?           @db.VarChar(255)
  type        ip_access_type
  status      ip_access_status? @default(active)
  created_at  DateTime          @default(now()) @db.DateTime(0)
  updated_at  DateTime          @default(now()) @updatedAt @db.DateTime(0)
}

model list_configs {
  id              Int                  @id @default(autoincrement())
  name            String               @db.VarChar(100)
  model           String               @db.VarChar(100)
  columns         String?              @db.LongText
  default_sort    String?              @db.LongText
  default_filters String?              @db.LongText
  page_size       Int?                 @default(20)
  is_default      Boolean?             @default(false)
  created_by      Int?
  status          list_configs_status? @default(active)
  created_at      DateTime             @default(now()) @db.DateTime(0)
  updated_at      DateTime             @default(now()) @updatedAt @db.DateTime(0)
}

model media_library {
  id            Int                 @id @default(autoincrement())
  title         String              @db.VarChar(255)
  description   String?             @db.Text
  filename      String              @db.VarChar(255)
  original_name String?             @db.VarChar(255)
  mime_type     String?             @db.VarChar(100)
  size          Int?
  type          media_library_type? @default(document)
  category      String?             @db.VarChar(100)
  path          String              @db.VarChar(500)
  url           String?             @db.VarChar(500)
  thumbnail_url String?             @db.VarChar(500)
  alt_text      String?             @db.VarChar(255)
  caption       String?             @db.VarChar(500)
  width         Int?
  height        Int?
  uploaded_by   Int?
  downloads     Int?                @default(0)
  views         Int?                @default(0)
  is_public     Boolean?            @default(true)
  is_featured   Boolean?            @default(false)
  metadata      String?             @db.LongText
  created_at    DateTime            @default(now()) @db.DateTime(0)
  updated_at    DateTime            @default(now()) @updatedAt @db.DateTime(0)

  @@index([category], map: "media_library_category")
  @@index([is_featured], map: "media_library_is_featured")
  @@index([is_public], map: "media_library_is_public")
  @@index([type], map: "media_library_type")
  @@index([uploaded_by], map: "media_library_uploaded_by")
}

model Menu {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  title      String?   @db.VarChar(200)
  path       String    @db.VarChar(500)
  icon       String?   @db.VarChar(100)
  parentId   Int?      @map("parent_id")
  sequence   Int?      @default(10)
  module     String    @db.VarChar(100)
  permission String?   @db.VarChar(200)
  viewName   String?   @map("view_name") @db.VarChar(100)
  hideInMenu Boolean?  @default(false) @map("hide_in_menu")
  isActive   Boolean?  @default(true) @map("is_active")
  createdAt  DateTime? @map("created_at") @db.DateTime(0)
  updatedAt  DateTime? @map("updated_at") @db.DateTime(0)
  parent     Menu?     @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "menus_ibfk_1")
  children   Menu[]    @relation("MenuHierarchy")

  @@index([parentId], map: "parent_id")
  @@map("menus")
}

model messages {
  id              Int                @id @default(autoincrement())
  subject         String?            @db.VarChar(255)
  content         String             @db.Text
  sender_name     String?            @db.VarChar(255)
  sender_email    String             @db.VarChar(255)
  sender_phone    String?            @db.VarChar(20)
  recipient_email String?            @db.VarChar(255)
  type            messages_type?     @default(contact)
  status          messages_status?   @default(new)
  priority        messages_priority? @default(normal)
  is_starred      Boolean?           @default(false)
  metadata        String?            @db.LongText
  read_at         DateTime?          @db.DateTime(0)
  replied_at      DateTime?          @db.DateTime(0)
  assigned_to     Int?
  created_at      DateTime           @default(now()) @db.DateTime(0)
  updated_at      DateTime           @default(now()) @updatedAt @db.DateTime(0)

  @@index([created_at], map: "messages_created_at")
  @@index([priority], map: "messages_priority")
  @@index([sender_email], map: "messages_sender_email")
  @@index([status], map: "messages_status")
  @@index([type], map: "messages_type")
}

model notification_channels {
  id           Int                                @id @default(autoincrement())
  name         String                             @db.VarChar(100)
  channel_type notification_channels_channel_type
  config       String?                            @db.LongText
  is_default   Boolean?                           @default(false)

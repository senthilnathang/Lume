# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Domain Configuration
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database Configuration
# DB_TYPE: mysql (default) or postgresql
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gawdesy_db
DB_USER=root
DB_PASSWORD=your_password
DB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@gawdesy.org

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Public Website URL (Nuxt.js app - used when website module is installed)
# When set, unauthenticated users hitting '/' are redirected here
PUBLIC_WEBSITE_URL=http://localhost:3100

# Session Secret
SESSION_SECRET=your-session-secret-change-in-production

# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Domain Configuration
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database Configuration (MySQL or PostgreSQL)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lume
DB_USER=root
DB_PASSWORD=your_password
DB_POOL_SIZE=10
DB_LOGGING=false

# Prisma Database URL (must match DB_* values above)
# MySQL:      mysql://user:password@host:port/database
# PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL="mysql://root:your_password@localhost:3306/lume"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@lume.dev

# Frontend URL (for CORS)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3100,http://localhost:3004

# Public Website URL (Nuxt.js SSR app)
PUBLIC_WEBSITE_URL=http://localhost:3100

# Session Secret
SESSION_SECRET=your-session-secret-change-in-production

# Rate Limiting (auto-enabled in production)
# ENABLE_RATE_LIMIT=true

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=logs

# OpenTelemetry Distributed Tracing Configuration
# Endpoint for OTLP collector (Jaeger, Datadog, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service identification in traces
OTEL_SERVICE_NAME=lume-backend
OTEL_SERVICE_VERSION=2.0.0

# Trace sampling configuration
# Sampler: parentbased_traceidratio (respects parent sampling decision)
OTEL_TRACES_SAMPLER=parentbased_traceidratio
# Sampling ratio: 0.0 - 1.0 (0 = no traces, 1 = all traces)
# Default: 1.0 in development (100% sampling), 0.1 in production (10% sampling)
OTEL_TRACES_SAMPLER_ARG=1.0

# Jaeger local agent (if using Jaeger collector instead of OTLP)
# JAEGER_AGENT_HOST=localhost
# JAEGER_AGENT_PORT=6831

# Optional: Cloud Logging Integrations
# LOGTAIL_SOURCE_TOKEN=
# DATADOG_API_KEY=

# Prometheus Metrics Configuration
# Enables Prometheus metrics collection and exposes /metrics endpoint
METRICS_ENABLED=true
# Service name for metrics (helps identify service in multi-service deployments)
OTEL_SERVICE_NAME=lume-backend
# Service version for metrics
OTEL_SERVICE_VERSION=2.0.0
# Instance ID for distributed deployments (defaults to hostname)
# INSTANCE_ID=lume-backend-1

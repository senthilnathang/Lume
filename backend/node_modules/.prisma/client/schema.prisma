// Prisma Schema for GAWDESY Backend
// Migrated from Sequelize for better performance and type safety

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(100)
  email     String    @unique @db.VarChar(100)
  password  String    @db.VarChar(255)
  firstName String?   @map("first_name") @db.VarChar(100)
  lastName  String?   @map("last_name") @db.VarChar(100)
  phone     String?   @db.VarChar(50)
  avatar    String?   @db.VarChar(255)
  role      Role      @default(VIEWER)
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  contactMessages ContactMessage[] @relation("Replies")

  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

model Organization {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  description String?  @db.Text
  logo        String?  @db.VarChar(255)
  address     String?  @db.VarChar(500)
  phone       String?  @db.VarChar(50)
  email       String?  @db.VarChar(100)
  website     String?  @db.VarChar(200)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  teamMembers TeamMember[]

  @@map("organizations")
}

model TeamMember {
  id             Int      @id @default(autoincrement())
  organizationId Int?     @map("organization_id")
  name           String   @db.VarChar(200)
  position       String?  @db.VarChar(100)
  bio            String?  @db.Text
  image          String?  @db.VarChar(255)
  phone          String?  @db.VarChar(50)
  email          String?  @db.VarChar(100)
  order          Int      @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@map("team_members")
}

model Programme {
  id               Int             @id @default(autoincrement())
  title            String          @db.VarChar(200)
  slug             String          @unique @db.VarChar(200)
  description      String?         @db.Text
  shortDescription String?         @map("short_description") @db.VarChar(500)
  image            String?         @db.VarChar(255)
  category         String?         @db.VarChar(100)
  status           ProgrammeStatus @default(DRAFT)
  startDate        DateTime?       @map("start_date")
  endDate          DateTime?       @map("end_date")
  targetAmount     Decimal?        @map("target_amount") @db.Decimal(10, 2)
  raisedAmount     Decimal?        @default(0) @map("raised_amount") @db.Decimal(10, 2)
  beneficiaryCount Int?            @map("beneficiary_count")
  isFeatured       Boolean         @default(false) @map("is_featured")
  metaTitle        String?         @map("meta_title") @db.VarChar(200)
  metaDescription  String?         @map("meta_description") @db.Text
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  activities Activity[]
  documents  Document[]
  donations  Donation[]

  @@map("programmes")
}

enum ProgrammeStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Activity {
  id               Int            @id @default(autoincrement())
  programmeId      Int?           @map("programme_id")
  title            String         @db.VarChar(200)
  slug             String         @unique @db.VarChar(200)
  description      String?        @db.Text
  image            String?        @db.VarChar(255)
  activityDate     DateTime?      @map("activity_date")
  location         String?        @db.VarChar(200)
  status           ActivityStatus @default(DRAFT)
  beneficiaryCount Int?           @map("beneficiary_count")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  programme Programme? @relation(fields: [programmeId], references: [id], onDelete: SetNull)

  @@map("activities")
}

enum ActivityStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

model Document {
  id            Int      @id @default(autoincrement())
  programmeId   Int?     @map("programme_id")
  title         String   @db.VarChar(200)
  description   String?  @db.Text
  filePath      String   @map("file_path") @db.VarChar(255)
  fileType      String?  @map("file_type") @db.VarChar(50)
  fileSize      Int?     @map("file_size")
  category      String?  @db.VarChar(100)
  isPublic      Boolean  @default(false) @map("is_public")
  downloadCount Int      @default(0) @map("download_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  programme Programme? @relation(fields: [programmeId], references: [id], onDelete: SetNull)

  @@map("documents")
}

model ContactMessage {
  id        Int           @id @default(autoincrement())
  name      String        @db.VarChar(200)
  email     String        @db.VarChar(100)
  phone     String?       @db.VarChar(50)
  subject   String?       @db.VarChar(200)
  message   String        @db.Text
  status    MessageStatus @default(NEW)
  repliedBy Int?          @map("replied_by")
  repliedAt DateTime?     @map("replied_at")
  reply     String?       @db.Text
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  replier User? @relation("Replies", fields: [repliedBy], references: [id], onDelete: SetNull)

  @@map("contact_messages")
}

enum MessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model Donor {
  id                Int         @id @default(autoincrement())
  name              String      @db.VarChar(200)
  email             String?     @db.VarChar(100)
  phone             String?     @db.VarChar(50)
  address           String?     @db.VarChar(500)
  anonymousDonation Boolean     @default(false) @map("anonymous_donation")
  status            DonorStatus @default(ACTIVE)
  totalDonated      Decimal?    @default(0) @map("total_donated") @db.Decimal(10, 2)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  donations Donation[]

  @@map("donors")
}

enum DonorStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model Donation {
  id            Int            @id @default(autoincrement())
  donorId       Int?           @map("donor_id")
  programmeId   Int?           @map("programme_id")
  amount        Decimal        @db.Decimal(10, 2)
  currency      String         @default("INR") @db.VarChar(10)
  paymentMethod String?        @map("payment_method") @db.VarChar(50)
  transactionId String?        @map("transaction_id") @db.VarChar(200)
  status        DonationStatus @default(PENDING)
  message       String?        @db.Text
  donatedAt     DateTime       @default(now()) @map("donated_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  donor     Donor?     @relation(fields: [donorId], references: [id], onDelete: SetNull)
  programme Programme? @relation(fields: [programmeId], references: [id], onDelete: SetNull)

  @@map("donations")
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

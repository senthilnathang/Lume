# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Domain Configuration
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database Configuration (MySQL or PostgreSQL)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lume
DB_USER=gawdesy
DB_PASSWORD=gawdesy
DB_POOL_SIZE=10
DB_LOGGING=false

# JWT Configuration
JWT_SECRET=lume-dev-jwt-secret-f8a3b1c9e4d7
JWT_REFRESH_SECRET=lume-dev-refresh-secret-a2c4e6f8b0d1
JWT_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@lume.dev

# Frontend URL (for CORS)
